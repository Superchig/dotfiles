#!/usr/bin/env python3
"""umu-helper - A helper script for running games via umu-run with Proton configuration."""

import argparse
import os
import subprocess
import sys
import tomllib
from pathlib import Path


PURPLE = "\033[95m"
RESET = "\033[0m"


def print_cmd(cmd: list[str]) -> None:
    print(f"{PURPLE}==== {' '.join(cmd)}{RESET}", file=sys.stderr)


def find_steam_proton_dir(start: Path) -> Path:
    """Recurse upwards from start until we find a steam_proton directory."""
    current = start
    while True:
        candidate = current / "steam_proton"
        if candidate.is_dir():
            return candidate
        parent = current.parent
        if parent == current:
            raise FileNotFoundError(
                "Could not find 'steam_proton' directory in any parent of: "
                + str(start)
            )
        current = parent


def find_config_toml(steam_proton_dir: Path) -> Path:
    """Search one level of subdirectories inside steam_proton_dir for a config.toml."""
    for child in steam_proton_dir.iterdir():
        if child.is_dir():
            config = child / "config.toml"
            if config.is_file():
                return config
    raise FileNotFoundError(
        f"No config.toml found in any subdirectory of: {steam_proton_dir}"
    )


def load_config(config_path: Path) -> dict:
    with open(config_path, "rb") as f:
        return tomllib.load(f)


def cmd_game(args: argparse.Namespace, config_path: Path, _config: dict) -> int:
    """Run umu-run with the config.toml file."""
    cmd = ["umu-run", "--config", str(config_path)] + args.extra
    print_cmd(cmd)
    result = subprocess.run(cmd)
    return result.returncode


def cmd_exe(args: argparse.Namespace, config: dict) -> int:
    """Run umu-run with prefix and proton set via environment variables."""
    try:
        umu_section = config["umu"]
        prefix = umu_section["prefix"]
        proton = umu_section["proton"]
    except KeyError as e:
        print(f"Error: Missing key in config.toml under [umu]: {e}", file=sys.stderr)
        return 1

    env = os.environ.copy()
    env["WINEPREFIX"] = str(prefix)
    env["PROTONPATH"] = str(proton)
    env["GAMEID"] = umu_section.get("id", "0")

    if not args.extra:
        print("Error: exe subcommand requires an executable path.", file=sys.stderr)
        return 1

    cmd = ["umu-run"] + args.extra
    print_cmd(cmd)
    result = subprocess.run(cmd, env=env)
    return result.returncode


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="umu-helper",
        description="Helper for running games via umu-run using steam_proton config.",
    )
    subparsers = parser.add_subparsers(dest="subcommand", required=True)

    game_parser = subparsers.add_parser(
        "game", help="Run umu-run using the config.toml file."
    )
    game_parser.add_argument(
        "extra",
        nargs="*",
        metavar="ARGS",
        help="Extra arguments passed to umu-run.",
    )

    exe_parser = subparsers.add_parser(
        "exe",
        help="Run umu-run with prefix/proton set via environment variables from config.toml.",
    )
    exe_parser.add_argument(
        "extra",
        nargs="*",
        metavar="EXE_AND_ARGS",
        help="Executable (and optional arguments) to run via umu-run.",
    )

    args = parser.parse_args()

    try:
        steam_proton_dir = find_steam_proton_dir(Path(os.getenv("PWD") or ""))
    except FileNotFoundError as e:
        print(f"Error: {e}", file=sys.stderr)
        return 1

    try:
        config_path = find_config_toml(steam_proton_dir)
    except FileNotFoundError as e:
        print(f"Error: {e}", file=sys.stderr)
        return 1

    config = load_config(config_path)

    if args.subcommand == "game":
        return cmd_game(args, config_path, config)
    elif args.subcommand == "exe":
        return cmd_exe(args, config)

    return 0


if __name__ == "__main__":
    sys.exit(main())
